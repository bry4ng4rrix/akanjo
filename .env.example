# ══════════════════════════════════════════════════════════════
# SYSTÈME DE GESTION DES STOCKS DE VÊTEMENTS
# VêteMart - Configuration Supabase
# ══════════════════════════════════════════════════════════════

# 📍 VARIABLES OBLIGATOIRES (à obtenir de Supabase)
# Copier-coller vos vraies valeurs ici

# 1️⃣  URL du projet Supabase
# Où le trouver: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 2️⃣  Clé d'authentification publique (côté client)
# Où le trouver: Supabase Dashboard → Settings → API → anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_anon_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3️⃣  Clé de service (côté serveur - SECRET!)
# Où le trouver: Supabase Dashboard → Settings → API → service_role key
# ⚠️  NE JAMAIS COMMITTER EN GIT - GARDER SECRET!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
